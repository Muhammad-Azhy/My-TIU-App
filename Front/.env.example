# Copy to `.env` and adjust for your machine. Restart Expo after changes.

# Web (Expo web / browser) — same machine as API
EXPO_PUBLIC_API_BASE_URL_WEB=http://localhost:3000/api

# Android emulator — host loopback to your PC
EXPO_PUBLIC_API_BASE_URL_ANDROID=http://10.0.2.2:3000/api

# Physical device (same Wi‑Fi as PC) — use your PC's LAN IP, not localhost
EXPO_PUBLIC_API_BASE_URL_DEVICE=http://192.168.1.25:3000/api
