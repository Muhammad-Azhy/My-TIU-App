# Copy to `.env` and restart Expo after changes (`npx expo start -c`).

# API port on your PC (must match Back/.env PORT)
EXPO_PUBLIC_API_PORT=3000

# Web / iOS Simulator (API on same machine)
EXPO_PUBLIC_API_BASE_URL_WEB=http://localhost:3000/api

# Android emulator only (10.0.2.2 = host machine from emulator)
EXPO_PUBLIC_API_BASE_URL_ANDROID=http://10.0.2.2:3000/api

# Physical device — use your PC LAN IP (ipconfig). Required for dev build APK on phone.
EXPO_PUBLIC_API_BASE_URL_DEVICE=http://YOUR_PC_WIFI_IP:3000/api

# Set after adding google-services.json + Back/.env Firebase vars (optional)
# EXPO_PUBLIC_ENABLE_FCM=true
