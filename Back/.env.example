# Runtime API + Prisma (MariaDB driver). Copy to `.env` and fill in values.

# JWT for auth tokens (use a long random string in production)
JWT_SECRET=change-me-in-production

# Server port
PORT=3000

# MariaDB / MySQL — used by `prisma/prismaClient.js` at runtime
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=mytiu

# Used by Prisma CLI for `prisma migrate` / `db push` (see prisma.config.ts).
# Put the real password in the URL, OR set DB_PASSWORD above: prisma.config.ts
# will inject DB_PASSWORD into DATABASE_URL when the URL has no password (avoids P1000 split-brain).
# Example with password: mysql://root:YOURPASS@127.0.0.1:3306/mytiu
DATABASE_URL=mysql://root:@127.0.0.1:3306/mytiu
